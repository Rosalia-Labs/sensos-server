#!/bin/bash

set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
SCRIPT_DIR="$(cd "$(dirname "${SCRIPT_PATH}")" && pwd)"
REPO_ROOT="${SCRIPT_DIR}"
STOP_SERVER_SCRIPT="${REPO_ROOT}/bin/stop-server"
PREFLIGHT_SCRIPT="${REPO_ROOT}/setup/00-preflight"
UNINSTALL_HELPER="${REPO_ROOT}/setup/uninstall"
DOCKER_DIR="${REPO_ROOT}/docker"
SYSTEM_INSTALL_STATE_FILE="/var/lib/sensos-server/install-state.env"
LOCAL_INSTALL_STATE_FILE="${REPO_ROOT}/.sensos-server/install-state.env"
SERVICE_NAME="${SENSOS_SERVICE_NAME:-sensos-server}"
PURGE_DATA=1
PURGE_IMAGES=1
REMOVE_SERVICE=1
NO_BACKUP=0
ASSUME_YES=0

log() {
    printf '[uninstall] %s\n' "$*"
}

die() {
    printf '[uninstall] ERROR: %s\n' "$*" >&2
    exit 1
}

print_usage() {
    cat <<EOF
Usage: ${SCRIPT_PATH} [options]

Stop the local SensOS server stack and remove optional host integration for this
repo checkout.

Options:
  --no-remove-data     Keep Docker volumes and host state
  --no-remove-images   Keep Docker images used by this repo's Compose stack
  --no-remove-service  Keep the optional ${SERVICE_NAME} systemd unit installed
  --no-backup       Skip backups when removing Docker volumes
  --yes             Skip the confirmation prompt
  --help            Show this help and exit
EOF
}

repo_owner() {
    if command -v stat >/dev/null 2>&1; then
        stat -c '%U' "${REPO_ROOT}" 2>/dev/null && return 0
        stat -f '%Su' "${REPO_ROOT}" 2>/dev/null && return 0
    fi

    die "unable to determine repo owner for ${REPO_ROOT}"
}

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --no-remove-data)
                PURGE_DATA=0
                ;;
            --no-remove-images)
                PURGE_IMAGES=0
                ;;
            --no-remove-service)
                REMOVE_SERVICE=0
                ;;
            --no-backup)
                NO_BACKUP=1
                ;;
            --yes)
                ASSUME_YES=1
                ;;
            --help|-h)
                print_usage
                exit 0
                ;;
            *)
                die "unknown option: $1"
                ;;
        esac
        shift
    done
}

confirm_uninstall() {
    local reply
    local action_summary="stop the Docker stack"

    if [[ "${REMOVE_SERVICE}" == "1" ]]; then
        action_summary="${action_summary}, remove the optional ${SERVICE_NAME} systemd unit"
    fi
    if [[ "${PURGE_DATA}" == "1" ]]; then
        action_summary="${action_summary}, remove Docker volumes, and delete host install state"
    else
        action_summary="${action_summary}, and remove install-state markers"
    fi
    if [[ "${PURGE_IMAGES}" == "1" ]]; then
        action_summary="${action_summary}, and remove Docker images for this stack"
    fi

    if [[ "${ASSUME_YES}" == "1" ]]; then
        return
    fi

    printf 'WARNING: this will %s for %s. Continue? [y/N] ' "${action_summary}" "${REPO_ROOT}"
    read -r reply
    [[ "${reply}" =~ ^[Yy]$ ]] || die "uninstall cancelled"
}

remove_local_install_state() {
    rm -f "${LOCAL_INSTALL_STATE_FILE}"
    rm -f "${SYSTEM_INSTALL_STATE_FILE}" 2>/dev/null || true
    log "removed repo-local install state markers"
}

stop_stack() {
    local -a stop_args=()

    [[ -x "${STOP_SERVER_SCRIPT}" ]] || die "missing or non-executable stop script: ${STOP_SERVER_SCRIPT}"

    if [[ "${PURGE_DATA}" == "1" ]]; then
        stop_args+=(--remove-volumes)
        if [[ "${NO_BACKUP}" == "1" ]]; then
            stop_args+=(--no-backup)
        fi
    fi

    log "stopping server stack"
    "${STOP_SERVER_SCRIPT}" "${stop_args[@]}"
}

compose_cmd() {
    if docker compose version >/dev/null 2>&1; then
        printf 'docker compose\n'
        return
    fi
    if command -v docker-compose >/dev/null 2>&1; then
        printf 'docker-compose\n'
        return
    fi
    die "Neither 'docker compose' nor 'docker-compose' is available."
}

purge_stack_images() {
    local -a compose=()
    local image_ids

    [[ "${PURGE_IMAGES}" == "1" ]] || return 0
    [[ -d "${DOCKER_DIR}" ]] || die "missing docker directory: ${DOCKER_DIR}"

    read -r -a compose <<< "$(compose_cmd)"

    image_ids="$(
        cd "${DOCKER_DIR}" && "${compose[@]}" images -q 2>/dev/null | awk 'NF' | sort -u
    )"

    if [[ -z "${image_ids}" ]]; then
        log "no stack images found to remove"
        return 0
    fi

    log "removing Docker images for this stack"
    # shellcheck disable=SC2086
    if ! docker image rm ${image_ids} >/dev/null; then
        log "some images could not be removed (possibly shared or in use); continuing"
    fi
}

sudo_run() {
    sudo env \
        "SENSOS_REPO_ROOT=${REPO_ROOT}" \
        "SENSOS_SERVICE_NAME=${SERVICE_NAME}" \
        "SENSOS_SERVICE_USER=${SENSOS_SERVICE_USER:-$(repo_owner)}" \
        "SENSOS_PURGE_STATE=${PURGE_DATA}" \
        "SENSOS_REMOVE_SERVICE=${REMOVE_SERVICE}" \
        "${UNINSTALL_HELPER}"
}

remove_host_integration() {
    [[ -x "${UNINSTALL_HELPER}" ]] || die "missing or non-executable uninstall helper: ${UNINSTALL_HELPER}"

    if [[ "${REMOVE_SERVICE}" != "1" && "${PURGE_DATA}" != "1" ]]; then
        remove_local_install_state
        return
    fi

    if [[ "${EUID}" -eq 0 ]]; then
        env \
            "SENSOS_REPO_ROOT=${REPO_ROOT}" \
            "SENSOS_SERVICE_NAME=${SERVICE_NAME}" \
            "SENSOS_PURGE_STATE=${PURGE_DATA}" \
            "SENSOS_REMOVE_SERVICE=${REMOVE_SERVICE}" \
            "${UNINSTALL_HELPER}"
    else
        sudo_run
    fi

    remove_local_install_state
}

main() {
    parse_args "$@"
    [[ -x "${PREFLIGHT_SCRIPT}" ]] || die "missing or non-executable preflight script: ${PREFLIGHT_SCRIPT}"
    env "SENSOS_REPO_ROOT=${REPO_ROOT}" "${PREFLIGHT_SCRIPT}" >/dev/null

    confirm_uninstall
    stop_stack
    purge_stack_images
    remove_host_integration
    log "uninstall complete"
}

main "$@"
