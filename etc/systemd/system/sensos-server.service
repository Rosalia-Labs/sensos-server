[Unit]
Description=SensOS Server
Wants=network-online.target
After=network-online.target docker.service
Requires=docker.service

[Service]
Type=simple
WorkingDirectory={{REPO_ROOT}}/docker
EnvironmentFile={{REPO_ROOT}}/docker/.env
ExecStart={{REPO_ROOT}}/bin/start-server --no-detach --restart
ExecStop={{REPO_ROOT}}/bin/stop-server
User={{SERVICE_USER}}
Restart=always
RestartSec=10
StartLimitIntervalSec=0
TimeoutStopSec=120

[Install]
WantedBy=multi-user.target
