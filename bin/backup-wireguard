#!/bin/bash
# SPDX-License-Identifier: MIT
# Copyright (c) 2025 Rosalia Labs LLC

set -euo pipefail

usage() {
    cat <<EOF
Usage: $(basename "$0") [options]

Create compressed WireGuard state backups from WireGuard-capable sensos
containers, storing them under ./backups.

Options:
  -h, --help  Show this help and exit
EOF
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            usage
            exit 0
            ;;
        *)
            echo "Unknown option: $1" >&2
            usage >&2
            exit 1
            ;;
    esac
done

WORK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$WORK_DIR"

BACKUP_DIR="${SENSOS_BACKUP_DIR:-./backups}"
TIMESTAMP=$(date +"%Y%m%d_%H%M%S")
mkdir -p "$BACKUP_DIR"

WIREGUARD_STATE_CONTAINERS=(
    "sensos-wireguard:/var/lib/sensos-wireguard"
    "sensos-api-proxy:/var/lib/sensos-api-proxy"
    "sensos-ops:/var/lib/sensos-ops"
)

backed_up_count=0

for container_state in "${WIREGUARD_STATE_CONTAINERS[@]}"; do
    container="${container_state%%:*}"
    state_dir="${container_state#*:}"
    echo "💾 Processing container: $container"

    if ! docker ps --filter "name=^${container}$" --format '{{.Names}}' | grep -q "^${container}$"; then
        echo "ℹ️  Container $container is not running. Skipping backup for this container."
        continue
    fi

    container_name="${container#sensos-}"
    WG_BACKUP_FILE="$BACKUP_DIR/wg_${container_name}_${TIMESTAMP}.tgz"

    echo "💾 Backing up WireGuard state from $container..."
    if docker exec "$container" sh -c '
        set -eu
        state_dir="$1"
        shift

        if [ -d "$state_dir" ] && find "$state_dir" -mindepth 1 -print -quit | grep -q .; then
            state_path="${state_dir#/}"
            set -- "$@" "$state_path"
        fi

        if [ -d /etc/wireguard ] && find /etc/wireguard -type f -name "*.conf" -print -quit | grep -q .; then
            set -- "$@" etc/wireguard
        fi

        if [ "$#" -eq 0 ]; then
            exit 2
        fi

        tar -C / -czf - "$@"
    ' sh "$state_dir" >"$WG_BACKUP_FILE"; then
        echo "✅ WireGuard backup completed for $container: $WG_BACKUP_FILE"
        chmod 600 "$WG_BACKUP_FILE"
        backed_up_count=$((backed_up_count + 1))
    else
        status=$?
        rm -f "$WG_BACKUP_FILE"
        if [ "$status" -eq 2 ]; then
            echo "ℹ️  No WireGuard state found in $container. Skipping backup for this container."
        else
            echo "❌ Failed to backup WireGuard state from $container. Exiting."
            exit 1
        fi
    fi
done

if [ "$backed_up_count" -eq 0 ]; then
    echo "❌ No WireGuard state backups were created. Exiting."
    exit 1
fi

echo "✅ All WireGuard backups completed successfully."
