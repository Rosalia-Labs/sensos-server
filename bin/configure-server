#!/bin/bash
# SPDX-License-Identifier: MIT
# Copyright (c) 2025 Rosalia Labs LLC

set -euo pipefail

WORK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../docker" && pwd)"

# Define default values
DEFAULT_API_PORT=8765
DEFAULT_API_BIND=127.0.0.1
DEFAULT_PUBLIC_UI_PORT=8780
DEFAULT_PUBLIC_UI_BIND=127.0.0.1
DEFAULT_POSTGRES_PASSWORD="sensos"
DEFAULT_ADMIN_API_PASSWORD="sensos-admin"
DEFAULT_CLIENT_API_PASSWORD="sensos-client"
DEFAULT_PUBLIC_DB_PASSWORD="sensos-public"
DEFAULT_UI_THEME=""

read_existing_env() {
    local key="$1"
    local value

    [[ -f .env ]] || return 0
    value="$(awk -F= -v key="$key" '$1 == key {print substr($0, length(key) + 2); exit}' .env)"
    [[ -n "${value}" ]] || return 0
    value="${value%$'\r'}"
    if [[ "${value}" == \'*\' && "${value}" == *\' ]]; then
        value="${value:1:${#value}-2}"
    fi
    printf '%s' "${value}"
}

# Print help message
print_help() {
    cat <<EOF
Usage: $0 [options]

Options:
  --api-port PORT          Set API port (default: $DEFAULT_API_PORT)
  --public-ui-port PORT    Set public dashboard port (default: $DEFAULT_PUBLIC_UI_PORT)
  --qemu-testing           Bind API/dashboard ports for two-VM QEMU testing
  --postgres-password PWD  Set PostgreSQL password (default: $DEFAULT_POSTGRES_PASSWORD)
  --admin-api-password PWD Set admin API password (default: $DEFAULT_ADMIN_API_PASSWORD)
  --client-api-password PWD Set client API password (default: $DEFAULT_CLIENT_API_PASSWORD)
  --public-db-password PWD Set read-only public dashboard DB password (default: $DEFAULT_PUBLIC_DB_PASSWORD)
  --ui-theme THEME         Optional UI theme override: default | vscode-dark (omitted: built-in default)
  -h, --help               Show this help message
EOF
    exit 0
}

# Allow command-line overrides
while [[ $# -gt 0 ]]; do
    case "$1" in
    --api-port)
        API_PORT="$2"
        shift 2
        ;;
    --public-ui-port)
        PUBLIC_UI_PORT="$2"
        shift 2
        ;;
    --qemu-testing)
        QEMU_TESTING=1
        shift
        ;;
    --postgres-password)
        POSTGRES_PASSWORD="$2"
        shift 2
        ;;
    --admin-api-password)
        ADMIN_API_PASSWORD="$2"
        shift 2
        ;;
    --client-api-password)
        CLIENT_API_PASSWORD="$2"
        shift 2
        ;;
    --public-db-password)
        PUBLIC_DB_PASSWORD="$2"
        shift 2
        ;;
    --ui-theme)
        UI_THEME="$2"
        shift 2
        ;;
    -h | --help)
        print_help
        ;;
    *)
        echo "Unknown option: $1" >&2
        print_help
        ;;
    esac
done

cd "$WORK_DIR"
echo "Working directory: $(pwd)"

EXISTING_API_PORT="$(read_existing_env API_PORT)"
EXISTING_API_BIND="$(read_existing_env API_BIND)"
EXISTING_PUBLIC_UI_PORT="$(read_existing_env PUBLIC_UI_PORT)"
EXISTING_PUBLIC_UI_BIND="$(read_existing_env PUBLIC_UI_BIND)"
EXISTING_POSTGRES_PASSWORD="$(read_existing_env POSTGRES_PASSWORD)"
EXISTING_ADMIN_API_PASSWORD="$(read_existing_env ADMIN_API_PASSWORD)"
EXISTING_CLIENT_API_PASSWORD="$(read_existing_env CLIENT_API_PASSWORD)"
EXISTING_PUBLIC_DB_PASSWORD="$(read_existing_env PUBLIC_DB_PASSWORD)"
EXISTING_UI_THEME="$(read_existing_env SENSOS_UI_THEME)"

# Set defaults if variables not provided
API_PORT=${API_PORT:-${EXISTING_API_PORT:-$DEFAULT_API_PORT}}
API_BIND=${API_BIND:-${EXISTING_API_BIND:-$DEFAULT_API_BIND}}
PUBLIC_UI_PORT=${PUBLIC_UI_PORT:-${EXISTING_PUBLIC_UI_PORT:-$DEFAULT_PUBLIC_UI_PORT}}
PUBLIC_UI_BIND=${PUBLIC_UI_BIND:-${EXISTING_PUBLIC_UI_BIND:-$DEFAULT_PUBLIC_UI_BIND}}
POSTGRES_PASSWORD=${POSTGRES_PASSWORD:-${EXISTING_POSTGRES_PASSWORD:-$DEFAULT_POSTGRES_PASSWORD}}
ADMIN_API_PASSWORD=${ADMIN_API_PASSWORD:-${EXISTING_ADMIN_API_PASSWORD:-$DEFAULT_ADMIN_API_PASSWORD}}
CLIENT_API_PASSWORD=${CLIENT_API_PASSWORD:-${EXISTING_CLIENT_API_PASSWORD:-$DEFAULT_CLIENT_API_PASSWORD}}
PUBLIC_DB_PASSWORD=${PUBLIC_DB_PASSWORD:-${EXISTING_PUBLIC_DB_PASSWORD:-$DEFAULT_PUBLIC_DB_PASSWORD}}
UI_THEME=${UI_THEME:-${EXISTING_UI_THEME:-$DEFAULT_UI_THEME}}

if [[ "${QEMU_TESTING:-0}" == "1" ]]; then
    API_BIND=0.0.0.0
    PUBLIC_UI_BIND=0.0.0.0
fi

if [[ -n "${UI_THEME}" && "${UI_THEME}" != "default" && "${UI_THEME}" != "vscode-dark" ]]; then
    echo "❌ Invalid --ui-theme '${UI_THEME}'. Allowed: default, vscode-dark." >&2
    exit 1
fi

quote_env_single() {
    local value="$1"
    if [[ "$value" == *"'"* ]]; then
        echo "❌ Password values cannot contain a single quote character (')." >&2
        echo "   Docker Compose .env parsing does not support shell-style escaping in single-quoted values." >&2
        return 1
    fi
    printf "'%s'" "$value"
}

POSTGRES_PASSWORD_Q="$(quote_env_single "$POSTGRES_PASSWORD")"
ADMIN_API_PASSWORD_Q="$(quote_env_single "$ADMIN_API_PASSWORD")"
CLIENT_API_PASSWORD_Q="$(quote_env_single "$CLIENT_API_PASSWORD")"
PUBLIC_DB_PASSWORD_Q="$(quote_env_single "$PUBLIC_DB_PASSWORD")"

# Backup existing .env if it exists
if [ -f .env ]; then
    mv .env .env.bak
    chmod 600 .env.bak
    echo "✅ Current environment configuration backed up to .env.bak."
fi

# Write configuration to .env
cat >.env <<EOF
API_PORT=$API_PORT
API_BIND=$API_BIND
PUBLIC_UI_PORT=$PUBLIC_UI_PORT
PUBLIC_UI_BIND=$PUBLIC_UI_BIND
POSTGRES_PASSWORD=$POSTGRES_PASSWORD_Q
ADMIN_API_PASSWORD=$ADMIN_API_PASSWORD_Q
CLIENT_API_PASSWORD=$CLIENT_API_PASSWORD_Q
PUBLIC_DB_PASSWORD=$PUBLIC_DB_PASSWORD_Q
EOF

if [[ -n "${UI_THEME}" ]]; then
    echo "SENSOS_UI_THEME=${UI_THEME}" >> .env
fi

chmod 600 .env
echo "✅ Environment configuration written to .env."
echo "✅ Setup completed successfully."
