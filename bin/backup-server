#!/bin/bash
# SPDX-License-Identifier: MIT
# Copyright (c) 2025 Rosalia Labs LLC

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
BACKUP_DIR="${SENSOS_BACKUP_DIR:-${REPO_ROOT}/backups}"
DEFAULT_POST_HOOK="${REPO_ROOT}/local/hooks/post-backup.sh"
EXPORT_AFTER_BACKUP=0
EXPORT_ARGS=()
TRANSFER_MODE_SET=0
REMOTE_OPTION_SET=0
POST_HOOK="${SENSOS_BACKUP_POST_HOOK:-}"
BACKUP_RUN_TIMESTAMP=""
MAX_ARTIFACT_BYTES="${SENSOS_BACKUP_MAX_ARTIFACT_BYTES:-14000000000}"

log() {
    printf '[backup-server] %s\n' "$*"
}

die() {
    printf '[backup-server] ERROR: %s\n' "$*" >&2
    exit 1
}

usage() {
    cat <<EOF
Usage: $(basename "$0") [options]

Create one standard server backup bundle. By default, the bundle stays local.

Options:
  --remote PATH     Copy the backup to this rclone destination after creation
  --move            With --remote/SENSOS_BACKUP_REMOTE, remove local files after upload
  --copy            With --remote/SENSOS_BACKUP_REMOTE, keep local files after upload (default)
  --post-hook PATH  Run a user-supplied script after backups complete
  --help            Show this help and exit

Hook contract:
  The post-hook receives the backup directory as argv[1], followed by the newly
  created top-level backup bundle paths as argv[2+].

Default local hook path:
  ${DEFAULT_POST_HOOK}

Environment:
  SENSOS_BACKUP_DIR
  SENSOS_BACKUP_REMOTE
  SENSOS_BACKUP_POST_HOOK
  SENSOS_BACKUP_MAX_ARTIFACT_BYTES  Default: ${MAX_ARTIFACT_BYTES}
EOF
}

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --remote)
                [[ $# -ge 2 ]] || die "--remote requires a value"
                EXPORT_AFTER_BACKUP=1
                REMOTE_OPTION_SET=1
                EXPORT_ARGS+=("$1" "$2")
                shift 2
                ;;
            --move|--copy)
                TRANSFER_MODE_SET=1
                EXPORT_ARGS+=("$1")
                shift
                ;;
            --post-hook)
                [[ $# -ge 2 ]] || die "--post-hook requires a value"
                POST_HOOK="$2"
                shift 2
                ;;
            --help|-h)
                usage
                exit 0
                ;;
            *)
                die "unknown option: $1"
                ;;
        esac
    done
}

validate_export_options() {
    if [[ -n "${SENSOS_BACKUP_REMOTE:-}" ]]; then
        EXPORT_AFTER_BACKUP=1
    fi
    if [[ "${TRANSFER_MODE_SET}" == "1" && "${EXPORT_AFTER_BACKUP}" != "1" ]]; then
        die "--copy/--move require --remote PATH or SENSOS_BACKUP_REMOTE"
    fi
}

resolve_post_hook() {
    if [[ -n "${POST_HOOK}" ]]; then
        return
    fi

    if [[ -x "${DEFAULT_POST_HOOK}" ]]; then
        POST_HOOK="${DEFAULT_POST_HOOK}"
    fi
}

collect_new_backups() {
    find "${BACKUP_DIR}" -maxdepth 1 -type f \( -name 'server_backup_*.tgz' -o -name 'server_backup_*.tgz.part-*' -o -name 'server_backup_*.parts.txt' -o -name 'db_backup_*.gz' -o -name 'wg_*.tgz' \) -print | sort
}

checksum_file() {
    if command -v sha256sum >/dev/null 2>&1; then
        sha256sum "$1" | awk '{print $1}'
    elif command -v shasum >/dev/null 2>&1; then
        shasum -a 256 "$1" | awk '{print $1}'
    else
        die "missing required command: sha256sum or shasum"
    fi
}

file_size_bytes() {
    wc -c <"$1" | awk '{print $1}'
}

validate_max_artifact_bytes() {
    [[ "${MAX_ARTIFACT_BYTES}" =~ ^[0-9]+$ ]] || die "SENSOS_BACKUP_MAX_ARTIFACT_BYTES must be an integer"
    [[ "${MAX_ARTIFACT_BYTES}" -gt 0 ]] || die "SENSOS_BACKUP_MAX_ARTIFACT_BYTES must be greater than zero"
}

split_large_bundle() {
    local bundle_path="$1"
    local bundle_name
    local bundle_size
    local bundle_sha256
    local chunk_prefix
    local parts_manifest
    local chunk_file
    local -a chunk_files=()

    bundle_name="$(basename "${bundle_path}")"
    bundle_size="$(file_size_bytes "${bundle_path}")"
    bundle_sha256="$(checksum_file "${bundle_path}")"

    if [[ "${bundle_size}" -le "${MAX_ARTIFACT_BYTES}" ]]; then
        printf '%s\n' "${bundle_path}"
        return
    fi

    chunk_prefix="${bundle_path}.part-"
    parts_manifest="${bundle_path%.tgz}.parts.txt"

    split -b "${MAX_ARTIFACT_BYTES}" -d -a 4 "${bundle_path}" "${chunk_prefix}"
    rm -f "${bundle_path}"

    {
        printf 'original_artifact=%s\n' "${bundle_name}"
        printf 'original_size_bytes=%s\n' "${bundle_size}"
        printf 'max_part_size_bytes=%s\n' "${MAX_ARTIFACT_BYTES}"
        printf 'original_sha256=%s\n' "${bundle_sha256}"
    } >"${parts_manifest}"

    printf 'parts=\n' >>"${parts_manifest}"
    for chunk_file in "${chunk_prefix}"*; do
        [[ -f "${chunk_file}" ]] || continue
        chunk_files+=("${chunk_file}")
        printf '  %s  %s  %s\n' \
            "$(basename "${chunk_file}")" \
            "$(file_size_bytes "${chunk_file}")" \
            "$(checksum_file "${chunk_file}")" >>"${parts_manifest}"
    done

    chmod 600 "${parts_manifest}" "${chunk_files[@]}"
    printf '%s\n' "${parts_manifest}"
    printf '%s\n' "${chunk_files[@]}"
}

bundle_new_backups() {
    local bundle_path
    local staging_dir
    local manifest_path
    local checksum_path
    local backup_file
    local backup_name
    local -a component_files=("$@")

    [[ "${#component_files[@]}" -gt 0 ]] || die "no backup component files were created"

    BACKUP_RUN_TIMESTAMP="$(date +"%Y%m%d_%H%M%S")"
    bundle_path="${BACKUP_DIR}/server_backup_${BACKUP_RUN_TIMESTAMP}.tgz"
    staging_dir="$(mktemp -d "${BACKUP_DIR}/.server_backup_${BACKUP_RUN_TIMESTAMP}.XXXXXX")"
    manifest_path="${staging_dir}/manifest.txt"
    checksum_path="${staging_dir}/SHA256SUMS"

    {
        printf 'created_at=%s\n' "$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
        printf 'repo_root=%s\n' "${REPO_ROOT}"
        printf 'artifact=%s\n' "$(basename "${bundle_path}")"
        printf 'components=\n'
    } >"${manifest_path}"

    : >"${checksum_path}"
    for backup_file in "${component_files[@]}"; do
        [[ -f "${backup_file}" ]] || die "component backup file not found: ${backup_file}"
        backup_name="$(basename "${backup_file}")"
        cp "${backup_file}" "${staging_dir}/${backup_name}"
        printf '  %s\n' "${backup_name}" >>"${manifest_path}"
        printf '%s  %s\n' "$(checksum_file "${backup_file}")" "${backup_name}" >>"${checksum_path}"
    done

    tar -C "${staging_dir}" -czf "${bundle_path}" .
    chmod 600 "${bundle_path}"
    rm -rf "${staging_dir}"

    for backup_file in "${component_files[@]}"; do
        rm -f "${backup_file}"
    done

    split_large_bundle "${bundle_path}"
}

main() {
    local before_list
    local after_list
    local backup_file
    local bundle_files
    local -a component_files=()
    local -a new_files=()

    parse_args "$@"
    validate_export_options
    validate_max_artifact_bytes
    resolve_post_hook
    before_list="$(collect_new_backups)"

    log "running database backup"
    "${SCRIPT_DIR}/backup-database"

    log "running wireguard backup"
    "${SCRIPT_DIR}/backup-wireguard"

    after_list="$(collect_new_backups)"
    while IFS= read -r backup_file; do
        [[ -n "${backup_file}" ]] || continue
        if ! grep -Fqx "${backup_file}" <<< "${before_list}"; then
            case "$(basename "${backup_file}")" in
                db_backup_*.gz|wg_*.tgz)
                    component_files+=("${backup_file}")
                    ;;
            esac
        fi
    done <<< "${after_list}"

    log "creating backup bundle"
    bundle_files="$(bundle_new_backups "${component_files[@]}")"
    while IFS= read -r backup_file; do
        [[ -n "${backup_file}" ]] || continue
        new_files+=("${backup_file}")
    done <<< "${bundle_files}"
    log "backup bundle created: ${new_files[*]}"

    if [[ "${EXPORT_AFTER_BACKUP}" == "1" ]]; then
        log "exporting backups"
        "${SCRIPT_DIR}/export-backups" "${EXPORT_ARGS[@]}"
    fi

    if [[ -n "${POST_HOOK}" ]]; then
        [[ -x "${POST_HOOK}" ]] || die "post-hook is not executable: ${POST_HOOK}"
        log "running post-hook ${POST_HOOK}"
        "${POST_HOOK}" "${BACKUP_DIR}" "${new_files[@]}"
    fi

    log "backup workflow complete"
}

main "$@"
