#!/bin/bash
# SPDX-License-Identifier: MIT
# Copyright (c) 2025 Rosalia Labs LLC

set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
SCRIPT_DIR="$(cd "$(dirname "${SCRIPT_PATH}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
ENV_FILE="${REPO_ROOT}/docker/.env"

CONFIG_SERVER="127.0.0.1"
API_PORT=""
WG_PUBLIC_IP=""
WG_PORT=""
API_PASSWORD=""
NETWORK_NAME=""
RESPONSE_FILE=""

log() {
    printf '[create-network] %s\n' "$*"
}

die() {
    printf '[create-network] ERROR: %s\n' "$*" >&2
    exit 1
}

usage() {
    cat <<EOF
Usage: $(basename "$0") [options] <network-name>

Create or reconcile a named WireGuard network through the running server API.

Options:
  --config-server HOST   API host to contact for network creation (default: ${CONFIG_SERVER})
  --port PORT            API port (default: value from docker/.env or 8765)
  --wg-public-ip IP      Reachable WireGuard endpoint IP or hostname for clients
  --wg-port PORT         WireGuard UDP port to publish for this network
  --api-password PASS    Override API password instead of reading docker/.env
  --help                 Show this help and exit
EOF
}

require_command() {
    command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"
}

load_env_defaults() {
    if [[ -f "${ENV_FILE}" ]]; then
        set -a
        # shellcheck disable=SC1090
        source "${ENV_FILE}"
        set +a
    fi

    API_PORT="${API_PORT:-8765}"
    WG_PUBLIC_IP="${WG_PUBLIC_IP:-}"
    WG_PORT="${WG_PORT:-}"
    API_PASSWORD="${SENSOS_API_PASSWORD:-${API_PASSWORD:-}}"
}

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --config-server)
                [[ $# -ge 2 ]] || die "--config-server requires a value"
                CONFIG_SERVER="$2"
                shift 2
                ;;
            --port)
                [[ $# -ge 2 ]] || die "--port requires a value"
                API_PORT="$2"
                shift 2
                ;;
            --wg-public-ip)
                [[ $# -ge 2 ]] || die "--wg-public-ip requires a value"
                WG_PUBLIC_IP="$2"
                shift 2
                ;;
            --wg-port)
                [[ $# -ge 2 ]] || die "--wg-port requires a value"
                WG_PORT="$2"
                shift 2
                ;;
            --api-password)
                [[ $# -ge 2 ]] || die "--api-password requires a value"
                API_PASSWORD="$2"
                shift 2
                ;;
            --help|-h)
                usage
                exit 0
                ;;
            --*)
                die "unknown option: $1"
                ;;
            *)
                [[ -z "${NETWORK_NAME}" ]] || die "unexpected extra argument: $1"
                NETWORK_NAME="$1"
                shift
                ;;
        esac
    done
}

validate_required() {
    [[ -n "${NETWORK_NAME}" ]] || die "network name is required"
    [[ -n "${API_PORT}" ]] || die "API port is not set"
    [[ -n "${WG_PUBLIC_IP}" ]] || die "WireGuard public IP is not set; pass --wg-public-ip"
    [[ -n "${WG_PORT}" ]] || die "WireGuard port is not set; pass --wg-port"
    [[ -n "${API_PASSWORD}" ]] || die "API password is not set; pass --api-password or configure API_PASSWORD in docker/.env"
}

print_summary() {
    local response_file="$1"

    python3 - "$response_file" "$CONFIG_SERVER" "$API_PORT" <<'PY'
import json
import sys

response_path, config_server, api_port = sys.argv[1:4]

with open(response_path, "r", encoding="utf-8") as f:
    data = json.load(f)

name = data["name"]
ip_range = data["ip_range"]
wg_public_ip = data["wg_public_ip"]
wg_port = data["wg_port"]
wg_public_key = data["wg_public_key"]

print(f"Network:    {name}")
print(f"CIDR:       {ip_range}")
print(f"WG endpoint:{wg_public_ip}:{wg_port}")
print(f"WG pubkey:  {wg_public_key}")
print()
print("Client setup example:")
print(
    f"  config-network --config-server {config_server} --port {api_port} --network {name}"
)

if wg_public_ip == "10.0.2.2":
    print()
    print("QEMU client VM example:")
    print(
        f"  config-network --config-server 10.0.2.2 --port 18765 --network {name}"
    )
PY
}

main() {
    local status_code

    require_command curl
    require_command python3
    load_env_defaults
    parse_args "$@"
    validate_required

    RESPONSE_FILE="$(mktemp)"
    trap 'rm -f "${RESPONSE_FILE}"' EXIT

    log "creating or reconciling network '${NETWORK_NAME}' via http://${CONFIG_SERVER}:${API_PORT}/create-network"
    if ! status_code="$(
        curl -sS \
            -o "${RESPONSE_FILE}" \
            -w '%{http_code}' \
            -u "sensos:${API_PASSWORD}" \
            -X POST \
            -F "name=${NETWORK_NAME}" \
            -F "wg_public_ip=${WG_PUBLIC_IP}" \
            -F "wg_port=${WG_PORT}" \
            "http://${CONFIG_SERVER}:${API_PORT}/create-network"
    )"; then
        die "failed to contact the server API at http://${CONFIG_SERVER}:${API_PORT}/create-network"
    fi

    if [[ "${status_code}" != "200" ]]; then
        printf '[create-network] ERROR: API returned HTTP %s\n' "${status_code}" >&2
        if [[ -s "${RESPONSE_FILE}" ]]; then
            cat "${RESPONSE_FILE}" >&2
        fi
        exit 1
    fi

    print_summary "${RESPONSE_FILE}"
}

main "$@"
