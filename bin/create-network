#!/bin/bash
# SPDX-License-Identifier: MIT
# Copyright (c) 2025 Rosalia Labs LLC

set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
SCRIPT_DIR="$(cd "$(dirname "${SCRIPT_PATH}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
ENV_FILE="${REPO_ROOT}/docker/.env"

API_PORT=""
WG_PUBLIC_HOST=""
WG_PORT=""
API_PASSWORD=""
NETWORK_NAME=""
RESPONSE_FILE=""

log() {
    printf '[create-network] %s\n' "$*"
}

die() {
    printf '[create-network] ERROR: %s\n' "$*" >&2
    exit 1
}

usage() {
    cat <<EOF
Usage: $(basename "$0") [options] <network-name>

Create or reconcile a named WireGuard network through the running server API.

Options:
  --wg-public-host HOST  Client-facing WireGuard endpoint host/address to store for later use
  --wg-port PORT         Client-facing WireGuard UDP port to store for later use
  --api-password PASS    Override API password instead of reading docker/.env
  --help                 Show this help and exit
EOF
}

require_command() {
    command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"
}

load_env_defaults() {
    if [[ -f "${ENV_FILE}" ]]; then
        set -a
        # shellcheck disable=SC1090
        source "${ENV_FILE}"
        set +a
    fi

    API_PORT="${API_PORT:-8765}"
    WG_PUBLIC_HOST="${WG_PUBLIC_IP:-${WG_PUBLIC_HOST:-}}"
    WG_PORT="${WG_PORT:-}"
    API_PASSWORD="${SENSOS_ADMIN_API_PASSWORD:-${ADMIN_API_PASSWORD:-${API_PASSWORD:-}}}"
}

resolve_public_ip() {
    local resolver
    local resolved_ip=""
    local -a resolvers=(
        "https://api.ipify.org"
        "https://ipv4.icanhazip.com"
    )

    for resolver in "${resolvers[@]}"; do
        if resolved_ip="$(curl -4 -fsS --connect-timeout 3 --max-time 10 "${resolver}" 2>/dev/null | tr -d '[:space:]')"; then
            if [[ "${resolved_ip}" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]]; then
                printf '%s\n' "${resolved_ip}"
                return
            fi
        fi
    done

    die "WireGuard public host is not set and automatic public IPv4 detection failed; set WG_PUBLIC_IP/WG_PUBLIC_HOST in docker/.env or pass --wg-public-host"
}

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --wg-public-host)
                [[ $# -ge 2 ]] || die "--wg-public-host requires a value"
                WG_PUBLIC_HOST="$2"
                shift 2
                ;;
            --wg-port)
                [[ $# -ge 2 ]] || die "--wg-port requires a value"
                WG_PORT="$2"
                shift 2
                ;;
            --api-password)
                [[ $# -ge 2 ]] || die "--api-password requires a value"
                API_PASSWORD="$2"
                shift 2
                ;;
            --help|-h)
                usage
                exit 0
                ;;
            --*)
                die "unknown option: $1"
                ;;
            *)
                [[ -z "${NETWORK_NAME}" ]] || die "unexpected extra argument: $1"
                NETWORK_NAME="$1"
                shift
                ;;
        esac
    done
}

validate_required() {
    [[ -n "${NETWORK_NAME}" ]] || die "network name is required"
    [[ -n "${API_PORT}" ]] || die "API port is not set"
    if [[ -z "${WG_PUBLIC_HOST}" ]]; then
        WG_PUBLIC_HOST="$(resolve_public_ip)"
    fi
    [[ -n "${API_PASSWORD}" ]] || die "admin API password is not set; pass --api-password or configure ADMIN_API_PASSWORD in docker/.env"
}

print_summary() {
    local response_file="$1"

    python3 - "$response_file" "$API_PORT" <<'PY'
import json
import sys

response_path, api_port = sys.argv[1:3]

with open(response_path, "r", encoding="utf-8") as f:
    data = json.load(f)

name = data["name"]
ip_range = data["ip_range"]
wg_public_host = data["wg_public_ip"]
wg_port = data["wg_port"]
wg_public_key = data["wg_public_key"]

print(f"Network:    {name}")
print(f"CIDR:       {ip_range}")
print(f"WG endpoint:{wg_public_host}:{wg_port}")
print(f"WG pubkey:  {wg_public_key}")
print()
print("Setup-time API example:")
print(
    f"  config-network --setup-server <server-host-or-ip> --setup-port {api_port} --network {name}"
)

if wg_public_host == "10.0.2.2":
    print()
    print("QEMU client VM example:")
    print(
        f"  config-network --setup-server 10.0.2.2 --setup-port 18765 --network {name}"
    )
PY
}

print_api_error() {
    local response_file="$1"

    python3 - "$response_file" <<'PY'
import json
import sys

response_path = sys.argv[1]

try:
    with open(response_path, "r", encoding="utf-8") as f:
        data = json.load(f)
except Exception:
    with open(response_path, "r", encoding="utf-8") as f:
        text = f.read().strip()
    if text:
        print(text)
    sys.exit(0)

if isinstance(data, dict) and data.get("error"):
    print(data["error"])
else:
    print(json.dumps(data))
PY
}

main() {
    local status_code
    local -a curl_args

    require_command curl
    require_command python3
    load_env_defaults
    parse_args "$@"
    validate_required

    RESPONSE_FILE="$(mktemp)"
    trap 'rm -f "${RESPONSE_FILE}"' EXIT
    local payload
    payload="$(
        python3 - "${NETWORK_NAME}" "${WG_PUBLIC_HOST}" "${WG_PORT:-}" <<'PY'
import json
import sys

payload = {
    "name": sys.argv[1],
    "wg_public_ip": sys.argv[2],
}
if len(sys.argv) > 3 and sys.argv[3]:
    payload["wg_port"] = int(sys.argv[3])
print(json.dumps(payload))
PY
)"

    curl_args=(
        -sS
        -o "${RESPONSE_FILE}"
        -w '%{http_code}'
        -u "sensos:${API_PASSWORD}"
        -H 'Content-Type: application/json'
        -X POST
        -d "${payload}"
    )

    log "creating or reconciling network '${NETWORK_NAME}' via http://127.0.0.1:${API_PORT}/api/v1/admin/networks"
    if ! status_code="$(
        curl "${curl_args[@]}" \
            "http://127.0.0.1:${API_PORT}/api/v1/admin/networks"
    )"; then
        die "failed to contact the server API at http://127.0.0.1:${API_PORT}/api/v1/admin/networks"
    fi

    if [[ "${status_code}" != "200" ]]; then
        printf '[create-network] ERROR: API returned HTTP %s\n' "${status_code}" >&2
        if [[ -s "${RESPONSE_FILE}" ]]; then
            print_api_error "${RESPONSE_FILE}" >&2
        fi
        exit 1
    fi

    print_summary "${RESPONSE_FILE}"
}

main "$@"
