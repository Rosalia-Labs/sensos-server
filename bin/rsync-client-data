#!/usr/bin/env bash
# SPDX-License-Identifier: MIT
# Copyright (c) 2025 Rosalia Labs LLC
#
# Copy /sensos/data/ from a remote client through the ops container.

set -euo pipefail
: "${OPS_CONTAINER:=sensos-ops}"
: "${OPS_SSH_KEY:=/var/lib/sensos-ops/ssh/id_ed25519}"
: "${OPS_KNOWN_HOSTS:=/var/lib/sensos-ops/ssh/known_hosts}"

usage() {
  cat <<EOF >&2
Usage: $(basename "$0") <ip-or-token> [--destination DIR] [rsync-options...]

Rsync /sensos/data/ from a client to a local directory (the current directory
by default). All arguments except --destination are passed unchanged to rsync.

Examples:
  $(basename "$0") testing_1_15 -av
  $(basename "$0") testing_1_15 --destination ./incoming -av --remove-source-files
  $(basename "$0") 10.23.1.15 --destination /srv/sensos-data -avn --delete
EOF
}

require_cmd() { command -v "$1" >/dev/null 2>&1 || { echo "Error: missing command $1" >&2; exit 127; }; }

require_container_running() {
  local n="$1"
  docker inspect "$n" >/dev/null 2>&1 || { echo "Error: container not found: $n" >&2; exit 1; }
  [[ "$(docker inspect -f '{{.State.Running}}' "$n" 2>/dev/null)" == "true" ]] || {
    echo "Error: container not running: $n" >&2; exit 1; }
}

is_ip() {
  local ip="$1"; [[ "$ip" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]] || return 1
  local a b c d n
  IFS='.' read -r a b c d <<<"$ip"
  for n in "$a" "$b" "$c" "$d"; do (( n>=0 && n<=255 )) || return 1; done
}

hash_octet_from_name() { printf %s "$1" | od -An -t u1 | awk '{for(i=1;i<=NF;i++) s+=$i} END{print s%256}'; }

build_ip_from_token() {
  local token="$1"
  if [[ ! "$token" =~ ^([A-Za-z0-9]+)[_-]([0-9]+)[_-]([0-9]+)$ ]]; then
    echo "Error: invalid token '$token'. Expected '<net>_<a>_<b>' or '<net>-<a>-<b>'." >&2
    exit 2
  fi
  local net="${BASH_REMATCH[1]}" a="${BASH_REMATCH[2]}" b="${BASH_REMATCH[3]}"
  (( a>=0 && a<=255 )) || { echo "Error: invalid octet $a" >&2; exit 2; }
  (( b>=0 && b<=255 )) || { echo "Error: invalid octet $b" >&2; exit 2; }
  local o2; o2="$(hash_octet_from_name "$net")"
  echo "10.${o2}.${a}.${b}"
}

# Rsync invokes this mode in place of ssh. Its arguments (including the host
# and remote rsync command) must remain byte-for-byte separate.
ssh_transport() {
  exec docker exec -i "$OPS_CONTAINER" ssh \
    -i "$OPS_SSH_KEY" \
    -o UserKnownHostsFile="$OPS_KNOWN_HOSTS" \
    -o StrictHostKeyChecking=accept-new \
    -o Compression=yes \
    -o TCPKeepAlive=no \
    -o ServerAliveInterval=60 \
    -o ServerAliveCountMax=3 \
    "$@"
}

main() {
  if [[ "${1:-}" == "--ssh-transport" ]]; then
    shift
    ssh_transport "$@"
  fi

  if [[ $# -eq 1 && ( "$1" == "-h" || "$1" == "--help" ) ]]; then
    usage
    exit 0
  fi
  [[ $# -ge 1 ]] || { usage; exit 2; }
  require_cmd docker; require_cmd rsync; require_cmd od; require_cmd awk

  local target="$1"; shift
  local ip
  if is_ip "$target"; then ip="$target"; else ip="$(build_ip_from_token "$target")"; fi

  local rsync_args=() destination="."
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --destination)
        [[ $# -ge 2 ]] || { echo "Error: --destination requires a directory" >&2; usage; exit 2; }
        destination="$2"
        shift 2
        ;;
      --destination=*)
        destination="${1#*=}"
        [[ -n "$destination" ]] || { echo "Error: --destination requires a directory" >&2; usage; exit 2; }
        shift
        ;;
      *)
        rsync_args+=("$1")
        shift
        ;;
    esac
  done

  require_container_running "$OPS_CONTAINER"

  local script_path
  script_path="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"
  exec rsync "${rsync_args[@]}" \
    -e "${script_path} --ssh-transport" \
    "sensos-admin@${ip}:/sensos/data/" "$destination"
}

main "$@"
