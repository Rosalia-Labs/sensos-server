#!/bin/bash

set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
SCRIPT_DIR="$(cd "$(dirname "${SCRIPT_PATH}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
SETUP_SCRIPT="${REPO_ROOT}/setup/install"
PREFLIGHT_SCRIPT="${REPO_ROOT}/setup/00-preflight"
SERVICE_NAME="${SENSOS_SERVICE_NAME:-sensos-server}"

log() {
    printf '[bin/install-service] %s\n' "$*"
}

die() {
    printf '[bin/install-service] ERROR: %s\n' "$*" >&2
    exit 1
}

die_privilege_hint() {
    die "$1
[bin/install-service] HINT: run this command from a privileged account (root or a user with sudo access)."
}

print_usage() {
    cat <<EOF
Usage: ${SCRIPT_PATH} [options]

Install or refresh the optional ${SERVICE_NAME} systemd service for this repo checkout.

Options:
  --help             Show this help and exit
EOF
}

repo_owner() {
    if command -v stat >/dev/null 2>&1; then
        stat -c '%U' "${REPO_ROOT}" 2>/dev/null && return 0
        stat -f '%Su' "${REPO_ROOT}" 2>/dev/null && return 0
    fi

    die "unable to determine repo owner for ${REPO_ROOT}"
}

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help|-h)
                print_usage
                exit 0
                ;;
            *)
                die "unknown option: $1"
                ;;
        esac
        shift
    done
}

confirm_install_target() {
    local reply

    printf 'WARNING: this will install or update the optional %s systemd service against %s. Continue? [y/N] ' "${SERVICE_NAME}" "${REPO_ROOT}"
    read -r reply
    [[ "${reply}" =~ ^[Yy]$ ]] || die "installation cancelled"
}

sudo_run() {
    sudo env \
        "SENSOS_REPO_ROOT=${REPO_ROOT}" \
        "SENSOS_SERVICE_NAME=${SERVICE_NAME}" \
        "SENSOS_SERVICE_USER=${SENSOS_SERVICE_USER:-$(repo_owner)}" \
        "$@"
}

main() {
    local service_user

    parse_args "$@"
    [[ -x "${SETUP_SCRIPT}" ]] || die "missing or non-executable setup script: ${SETUP_SCRIPT}"
    [[ -x "${PREFLIGHT_SCRIPT}" ]] || die "missing or non-executable preflight script: ${PREFLIGHT_SCRIPT}"
    service_user="${SENSOS_SERVICE_USER:-$(repo_owner)}"
    env "SENSOS_REPO_ROOT=${REPO_ROOT}" "${PREFLIGHT_SCRIPT}" >/dev/null

    confirm_install_target
    log "installing optional systemd service for ${REPO_ROOT}"

    if [[ "${EUID}" -eq 0 ]]; then
        if ! env \
            "SENSOS_REPO_ROOT=${REPO_ROOT}" \
            "SENSOS_SERVICE_NAME=${SERVICE_NAME}" \
            "SENSOS_SERVICE_USER=${service_user}" \
            "${SETUP_SCRIPT}"; then
            die_privilege_hint "service install failed while running as root"
        fi
    else
        if ! sudo_run "${SETUP_SCRIPT}"; then
            die_privilege_hint "service install failed; sudo could not complete setup"
        fi
    fi

    log "service install complete"
}

main "$@"
