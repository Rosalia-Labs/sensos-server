#!/bin/bash

set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
SCRIPT_DIR="$(cd "$(dirname "${SCRIPT_PATH}")" && pwd)"
REPO_ROOT="${SCRIPT_DIR}"
SETUP_SCRIPT="${REPO_ROOT}/setup/install"
PREFLIGHT_SCRIPT="${REPO_ROOT}/setup/00-preflight"
SERVICE_NAME="${SENSOS_SERVICE_NAME:-sensos-server}"

log() {
    printf '[install] %s\n' "$*"
}

die() {
    printf '[install] ERROR: %s\n' "$*" >&2
    exit 1
}

print_usage() {
    cat <<EOF
Usage: ${SCRIPT_PATH} [options]

Configure the current machine to run the SensOS server from this checkout.

Options:
  --help             Show this help and exit
EOF
}

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help|-h)
                print_usage
                exit 0
                ;;
            *)
                die "unknown option: $1"
                ;;
        esac
        shift
    done
}

ensure_not_root() {
    [[ "${EUID}" -ne 0 ]] || die "run ${SCRIPT_PATH} as the repo owner; it will use sudo for privileged steps"
}

confirm_install_target() {
    local reply

    printf 'WARNING: this will install or update the %s systemd service against %s. Continue? [y/N] ' "${SERVICE_NAME}" "${REPO_ROOT}"
    read -r reply
    [[ "${reply}" =~ ^[Yy]$ ]] || die "installation cancelled"
}

sudo_run() {
    sudo env \
        "SENSOS_REPO_ROOT=${REPO_ROOT}" \
        "SENSOS_SERVICE_NAME=${SERVICE_NAME}" \
        "SENSOS_SERVICE_USER=${SENSOS_SERVICE_USER:-${USER}}" \
        "$@"
}

main() {
    parse_args "$@"
    ensure_not_root
    [[ -x "${SETUP_SCRIPT}" ]] || die "missing or non-executable setup script: ${SETUP_SCRIPT}"
    [[ -x "${PREFLIGHT_SCRIPT}" ]] || die "missing or non-executable preflight script: ${PREFLIGHT_SCRIPT}"

    confirm_install_target
    log "running setup for ${REPO_ROOT}"
    sudo_run "${SETUP_SCRIPT}"
    log "install complete"
}

main "$@"
