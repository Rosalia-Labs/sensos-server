#!/bin/bash

set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
SCRIPT_DIR="$(cd "$(dirname "${SCRIPT_PATH}")" && pwd)"
REPO_ROOT="${SCRIPT_DIR}"

PREFLIGHT_SCRIPT="${REPO_ROOT}/setup/00-preflight"
MIGRATIONS_SCRIPT="${REPO_ROOT}/migrations/run"
SETUP_SCRIPT="${REPO_ROOT}/setup/install"
START_SERVER_SCRIPT="${REPO_ROOT}/bin/start-server"
SYSTEM_INSTALL_STATE_FILE="/var/lib/sensos-server/install-state.env"
LOCAL_INSTALL_STATE_FILE="${REPO_ROOT}/.sensos-server/install-state.env"
INSTALL_STATE_FILE=""
SERVICE_NAME="${SENSOS_SERVICE_NAME:-sensos-server}"
OFFLINE=0
REFRESH_SERVICE=0
RESTART_SERVICE=0

log() {
    printf '[upgrade] %s\n' "$*"
}

die() {
    printf '[upgrade] ERROR: %s\n' "$*" >&2
    exit 1
}

print_usage() {
    cat <<EOF
Usage: ${SCRIPT_PATH} [options]

Pull the latest repo changes, run migrations, and reconcile the installed server.

Options:
  --offline          Skip git pull and use the repo contents already on disk
  --refresh-service  Reinstall the optional ${SERVICE_NAME} systemd unit after upgrade
  --restart-service  Restart ${SERVICE_NAME} after setup completes
  --help             Show this help and exit
EOF
}

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --offline)
                OFFLINE=1
                ;;
            --refresh-service)
                REFRESH_SERVICE=1
                ;;
            --restart-service)
                RESTART_SERVICE=1
                ;;
            --help|-h)
                print_usage
                exit 0
                ;;
            *)
                die "unknown option: $1"
                ;;
        esac
        shift
    done
}

validate_version_text() {
    local version="$1"
    [[ "${version}" =~ ^[0-9]+\.[0-9]+\.[0-9]+([.-][A-Za-z0-9.-]+)?$ ]] || die "invalid version '${version}'"
}

read_repo_version() {
    local version_file="${REPO_ROOT}/VERSION"
    local version

    [[ -f "${version_file}" ]] || die "missing VERSION file at ${version_file}"
    version="$(head -n 1 "${version_file}" | tr -d '[:space:]')"
    [[ -n "${version}" ]] || die "VERSION file is empty"
    validate_version_text "${version}"
    printf '%s\n' "${version}"
}

read_repo_head() {
    git -C "${REPO_ROOT}" rev-parse HEAD
}

version_lt() {
    [[ "$1" != "$2" ]] && [[ "$(printf '%s\n%s\n' "$1" "$2" | sort -V | head -n 1)" == "$1" ]]
}

ensure_not_root() {
    [[ "${EUID}" -ne 0 ]] || die "run ${SCRIPT_PATH} as the repo owner"
}

ensure_git_repo() {
    git -C "${REPO_ROOT}" rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "not a git work tree: ${REPO_ROOT}"
}

ensure_clean_repo() {
    local status_output

    status_output="$(git -C "${REPO_ROOT}" status --porcelain --untracked-files=all)"
    status_output="$(printf '%s\n' "${status_output}" | grep -vE '^\?\? \.sensos-server(/|$)' || true)"
    if [[ -n "${status_output}" ]]; then
        printf '%s\n' "${status_output}" >&2
        die "repo is not clean. Commit or stash changes, then rerun ${SCRIPT_PATH}"
    fi
}

ensure_upstream() {
    git -C "${REPO_ROOT}" rev-parse --abbrev-ref --symbolic-full-name '@{u}' >/dev/null 2>&1 || die "current branch has no upstream; set one before running ${SCRIPT_PATH}"
}

resolve_install_state_file() {
    if [[ -n "${SENSOS_INSTALL_STATE_FILE:-}" ]]; then
        printf '%s\n' "${SENSOS_INSTALL_STATE_FILE}"
        return
    fi

    if [[ -e "${SYSTEM_INSTALL_STATE_FILE}" ]]; then
        if [[ -w "${SYSTEM_INSTALL_STATE_FILE}" ]]; then
            printf '%s\n' "${SYSTEM_INSTALL_STATE_FILE}"
        else
            printf '%s\n' "${LOCAL_INSTALL_STATE_FILE}"
        fi
        return
    fi

    if [[ -d "$(dirname "${SYSTEM_INSTALL_STATE_FILE}")" && -w "$(dirname "${SYSTEM_INSTALL_STATE_FILE}")" ]]; then
        printf '%s\n' "${SYSTEM_INSTALL_STATE_FILE}"
        return
    fi

    printf '%s\n' "${LOCAL_INSTALL_STATE_FILE}"
}

sudo_run() {
    if ! sudo env \
        "SENSOS_REPO_ROOT=${REPO_ROOT}" \
        "SENSOS_SERVICE_NAME=${SERVICE_NAME}" \
        "SENSOS_SERVICE_USER=${SENSOS_SERVICE_USER:-${USER}}" \
        "$@"; then
        die "sudo failed. Run ${SCRIPT_PATH} from an admin account for --refresh-service/--restart-service, or rerun without those flags as the repo owner"
    fi
}

read_installed_version() {
    if [[ -r "${INSTALL_STATE_FILE}" ]]; then
        awk -F= '/^INSTALLED_VERSION=/{print $2}' "${INSTALL_STATE_FILE}" 2>/dev/null || true
    fi
}

write_installed_state() {
    local state_dir="$1"
    local version="$2"

    mkdir -p "${state_dir}"
    cat > "${INSTALL_STATE_FILE}" <<EOF
INSTALLED_VERSION=${version}
REPO_ROOT=${REPO_ROOT}
SERVICE_NAME=${SERVICE_NAME}
SERVICE_USER=${SENSOS_SERVICE_USER:-${USER}}
EOF
    chmod 644 "${INSTALL_STATE_FILE}"
    log "recorded installed version in ${INSTALL_STATE_FILE}"
}

server_stack_running() {
    docker ps --filter "name=sensos-" --format '{{.Names}}' | grep -q .
}

reconcile_runtime_if_running() {
    if ! server_stack_running; then
        log "server containers are not running; skipping runtime rebuild/restart"
        return
    fi

    [[ -x "${START_SERVER_SCRIPT}" ]] || die "missing or non-executable start script: ${START_SERVER_SCRIPT}"
    log "rebuilding and restarting the running server stack"
    "${START_SERVER_SCRIPT}" --rebuild-containers --restart
}

main() {
    local old_version
    local source_version
    local new_version
    local old_head
    local new_head

    parse_args "$@"
    ensure_not_root
    INSTALL_STATE_FILE="$(resolve_install_state_file)"
    if [[ "${OFFLINE}" != "1" ]]; then
        ensure_git_repo
        ensure_clean_repo
        ensure_upstream
    fi

    [[ -x "${PREFLIGHT_SCRIPT}" ]] || die "missing or non-executable preflight script: ${PREFLIGHT_SCRIPT}"
    [[ -x "${MIGRATIONS_SCRIPT}" ]] || die "missing or non-executable migrations script: ${MIGRATIONS_SCRIPT}"
    [[ -x "${SETUP_SCRIPT}" ]] || die "missing or non-executable setup script: ${SETUP_SCRIPT}"

    log "verifying current server configuration"
    env "SENSOS_REPO_ROOT=${REPO_ROOT}" "${PREFLIGHT_SCRIPT}" >/dev/null

    source_version="$(read_repo_version)"
    old_version="$(read_installed_version)"
    if [[ -z "${old_version}" ]]; then
        old_version="${source_version}"
    fi

    if [[ "${OFFLINE}" == "1" ]]; then
        log "offline mode enabled; skipping git pull"
    else
        old_head="$(read_repo_head)"
        log "pulling the latest changes"
        git -C "${REPO_ROOT}" pull --ff-only
        new_head="$(read_repo_head)"
        if [[ "${new_head}" == "${old_head}" ]]; then
            log "git pull did not change HEAD; nothing to upgrade. Rerun with --offline to force a local upgrade."
            exit 0
        fi
    fi

    new_version="$(read_repo_version)"
    if [[ "${OFFLINE}" != "1" ]] && version_lt "${new_version}" "${old_version}"; then
        die "pulled revision moved repo version backward: ${old_version} -> ${new_version}"
    fi

    log "running migrations for ${old_version} -> ${new_version}"
    "${MIGRATIONS_SCRIPT}" "${old_version}" "${new_version}"
    write_installed_state "$(dirname "${INSTALL_STATE_FILE}")" "${new_version}"
    reconcile_runtime_if_running

    if [[ "${REFRESH_SERVICE}" == "1" ]]; then
        log "refreshing optional ${SERVICE_NAME} systemd service"
        sudo_run "${SETUP_SCRIPT}"
    fi

    if [[ "${RESTART_SERVICE}" == "1" ]]; then
        [[ "${REFRESH_SERVICE}" == "1" ]] || die "--restart-service requires --refresh-service"
        log "restarting ${SERVICE_NAME}"
        if ! sudo systemctl restart "${SERVICE_NAME}"; then
            die "sudo failed while restarting ${SERVICE_NAME}. Run ${SCRIPT_PATH} from an admin account for service management"
        fi
    fi

    log "upgrade complete at version ${new_version}"
}

main "$@"
