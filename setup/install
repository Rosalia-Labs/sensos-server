#!/bin/bash

set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
SCRIPT_DIR="$(cd "$(dirname "${SCRIPT_PATH}")" && pwd)"

log() {
    printf '[setup/install] %s\n' "$*"
}

die() {
    printf '[setup/install] ERROR: %s\n' "$*" >&2
    exit 1
}

require_root() {
    [[ "${EUID}" -eq 0 ]] || die "run as root"
}

run_step() {
    local step_path="$1"

    [[ -x "${step_path}" ]] || die "missing or non-executable setup step: ${step_path}"
    log "running $(basename "${step_path}")"
    "${step_path}"
}

main() {
    local step_path

    require_root

    while IFS= read -r step_path; do
        run_step "${step_path}"
    done < <(find "${SCRIPT_DIR}" -maxdepth 1 -type f -name '[0-9][0-9]-*' | sort)

    log "setup complete"
}

main "$@"
