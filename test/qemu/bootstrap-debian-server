#!/bin/bash

set -euo pipefail

TARGET_USER="${SENSOS_QEMU_USER:-sensos}"
REPO_URL="${SENSOS_QEMU_REPO_URL:-https://github.com/Rosalia-Labs/sensos-server.git}"
REPO_DIR_NAME="${SENSOS_QEMU_REPO_DIR:-sensos-server}"
APT_PACKAGES=(
    ca-certificates
    curl
    docker.io
    docker-compose
    git
)

log() {
    printf '[test/qemu/bootstrap-debian-server] %s\n' "$*"
}

die() {
    printf '[test/qemu/bootstrap-debian-server] ERROR: %s\n' "$*" >&2
    exit 1
}

require_root() {
    [[ "${EUID}" -eq 0 ]] || die "run this script as root inside the Debian guest"
}

ensure_group() {
    local name="$1"

    if ! getent group "${name}" >/dev/null; then
        log "creating group ${name}"
        groupadd "${name}"
    fi
}

ensure_user() {
    if id -u "${TARGET_USER}" >/dev/null 2>&1; then
        log "user ${TARGET_USER} already exists"
        return
    fi

    log "creating user ${TARGET_USER}"
    adduser --disabled-password --gecos "" "${TARGET_USER}"
}

ensure_group_membership() {
    local group_name="$1"

    if id -nG "${TARGET_USER}" | tr ' ' '\n' | grep -Fxq "${group_name}"; then
        log "user ${TARGET_USER} is already in ${group_name}"
        return
    fi

    log "adding user ${TARGET_USER} to ${group_name}"
    usermod -aG "${group_name}" "${TARGET_USER}"
}

install_packages() {
    export DEBIAN_FRONTEND=noninteractive

    log "updating apt package indexes"
    apt-get update
    log "installing packages: ${APT_PACKAGES[*]}"
    apt-get install -y --no-install-recommends "${APT_PACKAGES[@]}"
}

install_clone_helper() {
    local target_home helper_path

    target_home="$(getent passwd "${TARGET_USER}" | cut -d: -f6)"
    [[ -n "${target_home}" ]] || die "unable to determine home directory for ${TARGET_USER}"
    helper_path="${target_home}/clone-${REPO_DIR_NAME}"

    log "installing clone helper at ${helper_path}"
    cat > "${helper_path}" <<EOF
#!/bin/bash
set -euo pipefail

repo_url='${REPO_URL}'
repo_dir='${REPO_DIR_NAME}'
repo_path="\$HOME/\${repo_dir}"

rm -rf "\${repo_path}"
git clone "\${repo_url}" "\${repo_path}"
echo "cloned \${repo_url} into \${repo_path}"
EOF
    chown "${TARGET_USER}:${TARGET_USER}" "${helper_path}"
    chmod 0755 "${helper_path}"
}

print_next_steps() {
    local target_home repo_path helper_path

    target_home="$(getent passwd "${TARGET_USER}" | cut -d: -f6)"
    repo_path="${target_home}/${REPO_DIR_NAME}"
    helper_path="${target_home}/clone-${REPO_DIR_NAME}"

    cat <<EOF

Bootstrap complete.

Next steps:
  exit the install boot and stop QEMU
  start a disposable run boot with:
    test/qemu/run-debian-trixie-arm64 run

Then inside the guest:
  su - ${TARGET_USER}
  ${helper_path}
  cd ${repo_path}
  ./bin/configure-server
  ./bin/start-server

If you want the optional systemd unit, install and start it from a privileged
session after cloning the repo in a run boot:
  cd ${repo_path}
  ./bin/install-service
  su -c 'systemctl start sensos-server'

EOF
}

main() {
    require_root
    install_packages
    ensure_group docker
    ensure_user
    ensure_group_membership docker
    install_clone_helper
    print_next_steps
}

main "$@"
