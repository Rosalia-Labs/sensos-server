#!/bin/bash

set -euo pipefail

TARGET_USER="${SENSOS_QEMU_USER:-sensos}"
REPO_URL="${SENSOS_QEMU_REPO_URL:-https://github.com/Rosalia-Labs/sensos-server.git}"
REPO_DIR_NAME="${SENSOS_QEMU_REPO_DIR:-sensos-server}"
APT_PACKAGES=(
    ca-certificates
    curl
    docker-cli
    docker.io
    docker-compose
    git
)

log() {
    printf '[test/qemu/bootstrap-debian-server] %s\n' "$*"
}

die() {
    printf '[test/qemu/bootstrap-debian-server] ERROR: %s\n' "$*" >&2
    exit 1
}

require_root() {
    [[ "${EUID}" -eq 0 ]] || die "run this script as root inside the Debian guest"
}

ensure_group() {
    local name="$1"

    if ! getent group "${name}" >/dev/null; then
        log "creating group ${name}"
        groupadd "${name}"
    fi
}

ensure_user() {
    if id -u "${TARGET_USER}" >/dev/null 2>&1; then
        log "user ${TARGET_USER} already exists"
        return
    fi

    log "creating user ${TARGET_USER}"
    adduser --disabled-password --gecos "" "${TARGET_USER}"
}

ensure_group_membership() {
    local group_name="$1"

    if id -nG "${TARGET_USER}" | tr ' ' '\n' | grep -Fxq "${group_name}"; then
        log "user ${TARGET_USER} is already in ${group_name}"
        return
    fi

    log "adding user ${TARGET_USER} to ${group_name}"
    usermod -aG "${group_name}" "${TARGET_USER}"
}

install_packages() {
    export DEBIAN_FRONTEND=noninteractive

    log "updating apt package indexes"
    apt-get update
    log "installing packages: ${APT_PACKAGES[*]}"
    apt-get install -y --no-install-recommends "${APT_PACKAGES[@]}"
}

target_home() {
    getent passwd "${TARGET_USER}" | cut -d: -f6
}

repo_path() {
    printf '%s/%s\n' "$(target_home)" "${REPO_DIR_NAME}"
}

run_as_target_user() {
    local command="$1"
    su - "${TARGET_USER}" -c "${command}"
}

ensure_repo_checkout() {
    local repo_path_value

    repo_path_value="$(repo_path)"
    if [[ -d "${repo_path_value}/.git" ]]; then
        log "updating repo checkout at ${repo_path_value}"
        run_as_target_user "git -C '${repo_path_value}' fetch --all --prune"
        run_as_target_user "git -C '${repo_path_value}' pull --ff-only"
        return
    fi

    if [[ -e "${repo_path_value}" ]]; then
        log "removing non-git path at ${repo_path_value}"
        rm -rf "${repo_path_value}"
    fi

    log "cloning repo to ${repo_path_value}"
    run_as_target_user "git clone '${REPO_URL}' '${repo_path_value}'"
}

offer_shutdown() {
    if [[ ! -t 0 ]]; then
        return
    fi

    local reply
    printf '\nShut down the guest cleanly now? [Y/n] '
    read -r reply
    case "${reply:-Y}" in
        y|Y|yes|YES|"")
            log "shutting down guest"
            shutdown -h now
            ;;
        *)
            log "leaving guest running; shut it down cleanly before exiting QEMU"
            ;;
    esac
}

print_next_steps() {
    local repo_path_value

    repo_path_value="$(repo_path)"

    cat <<EOF

Bootstrap complete.

Next steps:
  shut the guest down cleanly from inside the VM
  once the guest is halted, use QEMU's Power Down or otherwise exit QEMU
  use a persistent update boot when you need to change the base VM later:
    test/qemu/run-debian-trixie-arm64 update
  start a disposable run boot with:
    test/qemu/run-debian-trixie-arm64 run

Then inside the guest:
  su - ${TARGET_USER}
  cd ${repo_path_value}
  ./bin/configure-server
  ./bin/start-server

If you want the optional systemd unit, install and start it from a privileged
session:
  cd ${repo_path_value}
  ./bin/install-service
  su -c 'systemctl start sensos-server'

EOF
}

main() {
    require_root
    install_packages
    ensure_group docker
    ensure_user
    ensure_group_membership docker
    ensure_repo_checkout
    print_next_steps
    offer_shutdown
}

main "$@"
