#!/bin/bash

set -euo pipefail

SCRIPT_NAME='[migrations/run]'

log() {
    printf '%s %s\n' "${SCRIPT_NAME}" "$*"
}

die() {
    printf '%s ERROR: %s\n' "${SCRIPT_NAME}" "$*" >&2
    exit 1
}

validate_version() {
    [[ "$1" =~ ^[0-9]+\.[0-9]+\.[0-9]+([.-][A-Za-z0-9.-]+)?$ ]] || die "invalid version '$1'"
}

version_lt() {
    [[ "$1" != "$2" ]] && [[ "$(printf '%s\n%s\n' "$1" "$2" | sort -V | head -n 1)" == "$1" ]]
}

version_ge() {
    ! version_lt "$1" "$2"
}

crosses_version() {
    local from_version="$1"
    local to_version="$2"
    local boundary="$3"

    version_lt "${from_version}" "${boundary}" && version_ge "${to_version}" "${boundary}"
}

database_container_running() {
    docker ps --filter "name=^/sensos-database$" --filter "status=running" --format '{{.Names}}' | grep -qx 'sensos-database'
}

run_database_sql() {
    docker exec -i sensos-database psql -U postgres -d postgres -v ON_ERROR_STOP=1
}

migrate_0_16_0_admin_user_accounts() {
    if ! command -v docker >/dev/null 2>&1; then
        log "docker is not available; controller startup will apply the admin user schema"
        return
    fi
    if ! docker info >/dev/null 2>&1; then
        log "docker daemon is not ready; controller startup will apply the admin user schema"
        return
    fi
    if ! database_container_running; then
        log "sensos-database is not running; controller startup will apply the admin user schema"
        return
    fi

    log "ensuring sensos.admin_users exists for named admin accounts"
    run_database_sql <<'SQL'
CREATE SCHEMA IF NOT EXISTS sensos;

CREATE TABLE IF NOT EXISTS sensos.admin_users (
    id SERIAL PRIMARY KEY,
    username TEXT UNIQUE NOT NULL,
    display_name TEXT,
    role TEXT NOT NULL DEFAULT 'viewer',
    password_hash TEXT NOT NULL,
    is_active BOOLEAN NOT NULL DEFAULT TRUE,
    created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    updated_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    last_login_at TIMESTAMPTZ,
    CHECK (role IN ('owner', 'operator', 'viewer')),
    CHECK (username ~ '^[A-Za-z0-9_.-]{3,64}$')
);

CREATE INDEX IF NOT EXISTS idx_admin_users_active_role
ON sensos.admin_users (is_active, role, username);

ALTER TABLE sensos.admin_users
ADD COLUMN IF NOT EXISTS display_name TEXT;

ALTER TABLE sensos.admin_users
ADD COLUMN IF NOT EXISTS last_login_at TIMESTAMPTZ;
SQL
}

main() {
    local from_version="${1:-}"
    local to_version="${2:-}"

    [[ -n "${from_version}" && -n "${to_version}" ]] || die "usage: $0 <from-version> <to-version>"
    validate_version "${from_version}"
    validate_version "${to_version}"

    if crosses_version "${from_version}" "${to_version}" "0.16.0"; then
        migrate_0_16_0_admin_user_accounts
    else
        log "no server migrations required for ${from_version} -> ${to_version}"
    fi
}

main "$@"
